{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "NAS-OS 是一个现代化的网络存储操作系统，提供卷管理、用户管理、共享管理、网络配置等功能。\n\n## 功能模块\n- **卷管理**: Btrfs 卷创建、快照、RAID 配置\n- **用户管理**: 用户/组管理、认证授权\n- **共享管理**: SMB/NFS 共享配置\n- **网络管理**: 网络接口、DDNS、防火墙、端口转发\n- **Docker 管理**: 容器、镜像、应用商店\n- **插件系统**: 可扩展的插件架构\n- **配额管理**: 存储配额控制\n- **性能监控**: 系统性能监控与报告",
        "title": "NAS-OS API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "NAS-OS 团队",
            "url": "https://github.com/nas-os/nas-os",
            "email": "support@nas-os.io"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "2.208.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
        "/system/health": {
            "get": {
                "description": "检查系统是否正常运行",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "健康检查",
                "responses": {
                    "200": {
                        "description": "系统健康",
                        "schema": {
                            "$ref": "#/definitions/web.HealthResponse"
                        }
                    }
                }
            }
        },
        "/system/info": {
            "get": {
                "description": "获取 NAS-OS 系统的基本信息",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "获取系统信息",
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes": {
            "get": {
                "description": "获取系统中所有 Btrfs 卷的列表",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "列出所有卷",
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "使用指定设备和配置创建新的 Btrfs 卷",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "创建新卷",
                "parameters": [
                    {
                        "description": "卷创建参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/web.VolumeCreateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "创建成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes/{name}": {
            "get": {
                "description": "根据卷名称获取卷的详细信息",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "获取卷详情",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "404": {
                        "description": "卷不存在",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            },
            "delete": {
                "description": "删除指定的 Btrfs 卷",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "删除卷",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "boolean",
                        "description": "强制删除",
                        "name": "force",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "删除成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes/{name}/devices": {
            "post": {
                "description": "向指定卷添加存储设备\n向指定卷添加存储设备",
                "consumes": [
                    "application/json",
                    "application/json"
                ],
                "produces": [
                    "application/json",
                    "application/json"
                ],
                "tags": [
                    "volumes",
                    "volumes"
                ],
                "summary": "添加设备到卷",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "设备参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/web.DeviceAddRequest"
                        }
                    },
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "设备参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/web.DeviceAddRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "添加成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes/{name}/devices/{device}": {
            "delete": {
                "description": "从指定卷移除存储设备",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "从卷移除设备",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "设备路径",
                        "name": "device",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "移除成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes/{name}/mount": {
            "post": {
                "description": "挂载指定的 Btrfs 卷",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "挂载卷",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "挂载成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes/{name}/snapshots": {
            "get": {
                "description": "获取指定卷的所有快照列表",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "snapshots"
                ],
                "summary": "列出快照",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes/{name}/subvolumes": {
            "get": {
                "description": "获取指定卷的所有子卷列表",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "列出子卷",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "在指定卷中创建新的子卷",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "创建子卷",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "子卷参数",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/web.SubVolumeCreateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "创建成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes/{name}/unmount": {
            "post": {
                "description": "卸载指定的 Btrfs 卷",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "卸载卷",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "卸载成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        },
        "/volumes/{name}/usage": {
            "get": {
                "description": "获取指定卷的存储使用情况",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "volumes"
                ],
                "summary": "获取卷使用量",
                "parameters": [
                    {
                        "type": "string",
                        "description": "卷名称",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/web.GenericResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "web.DeviceAddRequest": {
            "type": "object",
            "required": [
                "device"
            ],
            "properties": {
                "device": {
                    "type": "string",
                    "example": "/dev/sdc"
                }
            }
        },
        "web.GenericResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 0
                },
                "data": {},
                "message": {
                    "type": "string",
                    "example": "success"
                }
            }
        },
        "web.HealthResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 0
                },
                "message": {
                    "type": "string",
                    "example": "healthy"
                }
            }
        },
        "web.SubVolumeCreateRequest": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "example": "documents"
                }
            }
        },
        "web.VolumeCreateRequest": {
            "type": "object",
            "required": [
                "devices",
                "name"
            ],
            "properties": {
                "devices": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "/dev/sda",
                        "/dev/sdb"
                    ]
                },
                "name": {
                    "type": "string",
                    "example": "data-vol"
                },
                "profile": {
                    "description": "single, raid0, raid1, raid10, raid5, raid6",
                    "type": "string",
                    "example": "raid1"
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "description": "API 密钥认证",
            "type": "apiKey",
            "name": "token",
            "in": "query"
        },
        "BearerAuth": {
            "description": "JWT 认证令牌，格式：Bearer {token}",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    },
    "tags": [
        {
            "description": "卷管理 API - 创建、管理 Btrfs 存储卷",
            "name": "volumes"
        },
        {
            "description": "快照管理 API - 创建、恢复、删除快照",
            "name": "snapshots"
        },
        {
            "description": "用户管理 API - 用户和用户组的 CRUD 操作",
            "name": "users"
        },
        {
            "description": "认证 API - 登录、登出、令牌刷新",
            "name": "auth"
        },
        {
            "description": "共享管理 API - SMB 和 NFS 共享配置",
            "name": "shares"
        },
        {
            "description": "网络管理 API - 网络接口、DDNS、防火墙配置",
            "name": "network"
        },
        {
            "description": "Docker 管理 API - 容器、镜像、应用管理",
            "name": "docker"
        },
        {
            "description": "插件系统 API - 插件安装、配置、管理",
            "name": "plugins"
        },
        {
            "description": "配额管理 API - 存储配额设置与查询",
            "name": "quota"
        },
        {
            "description": "性能监控 API - 系统性能指标查询",
            "name": "perf"
        },
        {
            "description": "系统信息 API - 系统状态、健康检查",
            "name": "system"
        }
    ]
}