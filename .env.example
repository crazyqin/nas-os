# NAS-OS 生产环境配置示例
# 复制此文件为 .env 并根据实际环境修改
# 
# 使用方式:
#   cp .env.example .env
#   编辑 .env 文件
#   docker compose -f docker-compose.prod.yml up -d

# ==================== NAS-OS 配置 ====================
NAS_OS_IMAGE=ghcr.io/nas-os/nas-os:latest
CONFIG_PATH=./configs
LOG_PATH=./logs
NAS_OS_DATA_PATH=/var/lib/nas-os

# 资源限制
NAS_OS_CPU_LIMIT=4.0
NAS_OS_MEMORY_LIMIT=4G
NAS_OS_CPU_RESERVATION=1.0
NAS_OS_MEMORY_RESERVATION=1G

# ==================== 时区配置 ====================
TZ=Asia/Shanghai

# ==================== 日志配置 ====================
LOG_LEVEL=info

# ==================== Prometheus 配置 ====================
PROMETHEUS_PORT=9090
PROMETHEUS_CONFIG=./monitoring/prometheus.yml
PROMETHEUS_RULES=./monitoring/alerts.yml
PROMETHEUS_DATA_PATH=/var/lib/prometheus
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ==================== Grafana 配置 ====================
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_DATA_PATH=/var/lib/grafana
GRAFANA_PROVISIONING=./monitoring/grafana/provisioning

# ==================== Alertmanager 配置 ====================
ALERTMANAGER_PORT=9093
ALERTMANAGER_CONFIG=./monitoring/alertmanager.yml
ALERTMANAGER_DATA_PATH=/var/lib/alertmanager

# ==================== Node Exporter 配置 ====================
NODE_EXPORTER_PORT=9100

# ==================== cAdvisor 配置 ====================
CADVISOR_PORT=8081

# ==================== SMTP 配置（告警邮件） ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=nas-os@example.com
SMTP_USER=nas-os@example.com
SMTP_PASSWORD=changeme

# ==================== Docker Hub 凭证（CI/CD） ====================
# 仅用于 GitHub Actions
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=

# ==================== 调试模式 ====================
DEBUG=false