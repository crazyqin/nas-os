# NAS-OS 开发环境 Dockerfile
# 基于 Air 实现热重载
#
# 使用方式:
#   docker compose -f docker-compose.dev.yml up -d
#
# v2.173.0 更新（工部优化）：
# - 升级 Go 版本至 1.26（匹配当前系统版本）
#
# v2.240.0 更新（工部优化）：
# - 修复 Go 版本号（1.26 → 1.24，Go 1.26 尚未发布）
#
# v2.34.0 初始配置
# v2.91.0 修复 Air 安装命令、EXPOSE 注释格式

# ========== 开发阶段 ==========
FROM golang:1.24-alpine

WORKDIR /app

# 安装开发依赖
RUN apk add --no-cache \
    git \
    curl \
    wget \
    bash \
    gcc \
    musl-dev \
    sqlite-dev \
    btrfs-progs \
    samba \
    nfs-utils \
    ca-certificates \
    tzdata \
    procps \
    && rm -rf /var/cache/apk/*

# 安装 Air（热重载工具）和 Delve（调试器）
RUN go install github.com/air-verse/air@latest && \
    go install github.com/go-delve/delve/cmd/dlv@latest

# 配置 Air
COPY .air.toml /app/.air.toml

# 复制 go mod 文件
COPY go.mod go.sum ./

# 下载依赖
RUN go mod download

# 复制源码
COPY . .

# 创建必要的目录
RUN mkdir -p /var/lib/nas-os /var/log/nas-os /etc/nas-os && \
    chmod 755 /var/lib/nas-os /var/log/nas-os /etc/nas-os

# 暴露端口
EXPOSE 8080/tcp
# Delve debugger
EXPOSE 2345/tcp

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD wget -q --spider http://localhost:8080/api/v1/health || exit 1

# 使用 Air 启动（支持热重载）
CMD ["air", "-c", ".air.toml"]