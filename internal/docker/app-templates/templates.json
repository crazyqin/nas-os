{
  "templates": [
    {
      "id": "nextcloud",
      "name": "Nextcloud",
      "displayName": "Nextcloud",
      "description": "私有云存储和协作平台，支持文件同步、日历、联系人等",
      "category": "Productivity",
      "icon": "📁",
      "version": "latest",
      "image": "nextcloud:latest",
      "ports": [{"port": 80, "protocol": "tcp", "description": "Web 界面", "default": 8080}],
      "volumes": [
        {"containerPath": "/var/www/html", "description": "应用数据", "default": "/opt/nas/apps/nextcloud/html"},
        {"containerPath": "/var/www/html/custom_apps", "description": "自定义应用", "default": "/opt/nas/apps/nextcloud/apps"},
        {"containerPath": "/var/www/html/config", "description": "配置文件", "default": "/opt/nas/apps/nextcloud/config"},
        {"containerPath": "/var/www/html/data", "description": "用户数据", "default": "/opt/nas/apps/nextcloud/data"}
      ],
      "environment": {"NEXTCLOUD_ADMIN_USER": "admin", "NEXTCLOUD_ADMIN_PASSWORD": "admin123"},
      "notes": "首次访问需要设置管理员账户",
      "website": "https://nextcloud.com"
    },
    {
      "id": "homeassistant",
      "name": "Home Assistant",
      "displayName": "Home Assistant",
      "description": "开源智能家居自动化平台",
      "category": "Home Automation",
      "icon": "🏠",
      "version": "stable",
      "image": "homeassistant/home-assistant:stable",
      "ports": [{"port": 8123, "protocol": "tcp", "description": "Web 界面", "default": 8123}],
      "volumes": [
        {"containerPath": "/config", "description": "配置文件", "default": "/opt/nas/apps/homeassistant/config"}
      ],
      "environment": {"TZ": "Asia/Shanghai"},
      "notes": "支持数千种智能设备集成",
      "website": "https://www.home-assistant.io"
    },
    {
      "id": "plex",
      "name": "Plex",
      "displayName": "Plex Media Server",
      "description": "强大的媒体服务器，支持视频、音乐、照片管理",
      "category": "Media",
      "icon": "🎬",
      "version": "latest",
      "image": "plexinc/pms-docker:latest",
      "ports": [
        {"port": 32400, "protocol": "tcp", "description": "Web 界面", "default": 32400},
        {"port": 3005, "protocol": "tcp", "description": "GDM", "default": 3005},
        {"port": 8324, "protocol": "tcp", "description": "Plex DLNA", "default": 8324},
        {"port": 32469, "protocol": "tcp", "description": "Plex DLNA", "default": 32469}
      ],
      "volumes": [
        {"containerPath": "/config", "description": "配置文件", "default": "/opt/nas/apps/plex/config"},
        {"containerPath": "/media", "description": "媒体库", "default": "/opt/nas/media"},
        {"containerPath": "/transcode", "description": "转码临时目录", "default": "/opt/nas/apps/plex/transcode"}
      ],
      "environment": {"PLEX_CLAIM": "claim-xxx", "TZ": "Asia/Shanghai", "LANG": "zh_CN.UTF-8"},
      "notes": "需要 Plex Claim Token 进行首次配置",
      "website": "https://www.plex.tv"
    },
    {
      "id": "jellyfin",
      "name": "Jellyfin",
      "displayName": "Jellyfin",
      "description": "开源免费的媒体服务器，无许可证限制",
      "category": "Media",
      "icon": "📺",
      "version": "latest",
      "image": "jellyfin/jellyfin:latest",
      "ports": [{"port": 8096, "protocol": "tcp", "description": "Web 界面", "default": 8096}],
      "volumes": [
        {"containerPath": "/config", "description": "配置文件", "default": "/opt/nas/apps/jellyfin/config"},
        {"containerPath": "/media", "description": "媒体库", "default": "/opt/nas/media"}
      ],
      "environment": {"TZ": "Asia/Shanghai"},
      "notes": "完全免费开源，支持硬件转码",
      "website": "https://jellyfin.org"
    },
    {
      "id": "pihole",
      "name": "Pi-hole",
      "displayName": "Pi-hole",
      "description": "网络级广告拦截和 DNS 服务器",
      "category": "Network",
      "icon": "🛡️",
      "version": "latest",
      "image": "pihole/pihole:latest",
      "ports": [
        {"port": 53, "protocol": "udp", "description": "DNS", "default": 53},
        {"port": 80, "protocol": "tcp", "description": "管理界面", "default": 8080},
        {"port": 443, "protocol": "tcp", "description": "HTTPS", "default": 8443}
      ],
      "volumes": [
        {"containerPath": "/etc/pihole", "description": "配置文件", "default": "/opt/nas/apps/pihole/pihole"},
        {"containerPath": "/etc/dnsmasq.d", "description": "DNSMasq 配置", "default": "/opt/nas/apps/pihole/dnsmasq.d"}
      ],
      "environment": {"TZ": "Asia/Shanghai", "WEBPASSWORD": "admin"},
      "notes": "需要将路由器 DNS 指向此服务器",
      "website": "https://pi-hole.net"
    },
    {
      "id": "transmission",
      "name": "Transmission",
      "displayName": "Transmission",
      "description": "轻量级 BitTorrent 客户端",
      "category": "Download",
      "icon": "📥",
      "version": "latest",
      "image": "linuxserver/transmission:latest",
      "ports": [
        {"port": 9091, "protocol": "tcp", "description": "Web 界面", "default": 9091},
        {"port": 51413, "protocol": "tcp", "description": "BT 端口", "default": 51413},
        {"port": 51413, "protocol": "udp", "description": "BT 端口", "default": 51413}
      ],
      "volumes": [
        {"containerPath": "/config", "description": "配置文件", "default": "/opt/nas/apps/transmission/config"},
        {"containerPath": "/downloads", "description": "下载目录", "default": "/opt/nas/downloads"}
      ],
      "environment": {"PUID": "1000", "PGID": "1000", "TZ": "Asia/Shanghai", "USER": "admin", "PASS": "admin123"},
      "notes": "支持磁力链接和种子文件",
      "website": "https://transmissionbt.com"
    },
    {
      "id": "qbittorrent",
      "name": "qBittorrent",
      "displayName": "qBittorrent",
      "description": "功能丰富的 BitTorrent 客户端",
      "category": "Download",
      "icon": "🧲",
      "version": "latest",
      "image": "linuxserver/qbittorrent:latest",
      "ports": [{"port": 8080, "protocol": "tcp", "description": "Web 界面", "default": 8080}],
      "volumes": [
        {"containerPath": "/config", "description": "配置文件", "default": "/opt/nas/apps/qbittorrent/config"},
        {"containerPath": "/downloads", "description": "下载目录", "default": "/opt/nas/downloads"}
      ],
      "environment": {"PUID": "1000", "PGID": "1000", "TZ": "Asia/Shanghai", "WEBUI_PORT": "8080"},
      "notes": "支持 RSS、搜索插件等高级功能",
      "website": "https://www.qbittorrent.org"
    },
    {
      "id": "sonarr",
      "name": "Sonarr",
      "displayName": "Sonarr",
      "description": "电视节目自动下载和管理工具",
      "category": "Media",
      "icon": "📺",
      "version": "latest",
      "image": "linuxserver/sonarr:latest",
      "ports": [{"port": 8989, "protocol": "tcp", "description": "Web 界面", "default": 8989}],
      "volumes": [
        {"containerPath": "/config", "description": "配置文件", "default": "/opt/nas/apps/sonarr/config"},
        {"containerPath": "/tv", "description": "电视节目目录", "default": "/opt/nas/media/tv"},
        {"containerPath": "/downloads", "description": "下载目录", "default": "/opt/nas/downloads"}
      ],
      "environment": {"PUID": "1000", "PGID": "1000", "TZ": "Asia/Shanghai"},
      "notes": "配合 Transmission/qBittorrent 使用",
      "website": "https://sonarr.tv"
    },
    {
      "id": "radarr",
      "name": "Radarr",
      "displayName": "Radarr",
      "description": "电影自动下载和管理工具",
      "category": "Media",
      "icon": "🎥",
      "version": "latest",
      "image": "linuxserver/radarr:latest",
      "ports": [{"port": 7878, "protocol": "tcp", "description": "Web 界面", "default": 7878}],
      "volumes": [
        {"containerPath": "/config", "description": "配置文件", "default": "/opt/nas/apps/radarr/config"},
        {"containerPath": "/movies", "description": "电影目录", "default": "/opt/nas/media/movies"},
        {"containerPath": "/downloads", "description": "下载目录", "default": "/opt/nas/downloads"}
      ],
      "environment": {"PUID": "1000", "PGID": "1000", "TZ": "Asia/Shanghai"},
      "notes": "配合 Transmission/qBittorrent 使用",
      "website": "https://radarr.video"
    },
    {
      "id": "emby",
      "name": "Emby",
      "displayName": "Emby Server",
