    {
      "id": "navidrome",
      "name": "Navidrome",
      "displayName": "Navidrome",
      "description": "轻量级音乐服务器，支持 Subsonic API",
      "category": "Media",
      "icon": "🎵",
      "version": "latest",
      "image": "deluan/navidrome:latest",
      "ports": [{"port": 4533, "protocol": "tcp", "description": "Web 界面", "default": 4533}],
      "volumes": [
        {"containerPath": "/data", "description": "配置和数据库", "default": "/opt/nas/apps/navidrome/data"},
        {"containerPath": "/music", "description": "音乐库", "default": "/opt/nas/media/music"}
      ],
      "environment": {"ND_SCANSCHEDULE": "1h", "ND_LOGLEVEL": "info", "ND_SESSIONTIMEOUT": "24h"},
      "notes": "支持多种客户端应用",
      "website": "https://www.navidrome.org"
    },
    {
      "id": "immich",
      "name": "Immich",
      "displayName": "Immich",
      "description": "自托管照片和视频备份解决方案",
      "category": "Media",
      "icon": "📸",
      "version": "latest",
      "image": "ghcr.io/immich-app/immich-server:latest",
      "ports": [{"port": 2283, "protocol": "tcp", "description": "Web 界面", "default": 2283}],
      "volumes": [
        {"containerPath": "/upload", "description": "上传目录", "default": "/opt/nas/apps/immich/upload"},
        {"containerPath": "/library", "description": "媒体库", "default": "/opt/nas/apps/immich/library"}
      ],
      "environment": {"DB_HOSTNAME": "immich-postgres", "DB_DATABASE_NAME": "immich", "DB_USERNAME": "postgres", "DB_PASSWORD": "immich"},
      "notes": "需要配合 PostgreSQL 和 Redis 使用",
      "website": "https://immich.app"
    },
    {
      "id": "photoprism",
      "name": "PhotoPrism",
      "displayName": "PhotoPrism",
      "description": "AI 驱动的照片管理应用",
      "category": "Media",
      "icon": "🖼️",
      "version": "latest",
      "image": "photoprism/photoprism:latest",
      "ports": [{"port": 2342, "protocol": "tcp", "description": "Web 界面", "default": 2342}],
      "volumes": [
        {"containerPath": "/photoprism/storage", "description": "存储目录", "default": "/opt/nas/apps/photoprism/storage"},
        {"containerPath": "/photoprism/originals", "description": "原始照片", "default": "/opt/nas/apps/photoprism/originals"}
      ],
      "environment": {"PHOTOPRISM_ADMIN_PASSWORD": "admin", "PHOTOPRISM_SITE_URL": "http://localhost:2342", "TZ": "Asia/Shanghai"},
      "notes": "支持 AI 自动分类和标签",
      "website": "https://photoprism.app"
    },
    {
      "id": "grafana",
      "name": "Grafana",
      "displayName": "Grafana",
      "description": "数据可视化和监控仪表板",
      "category": "Monitoring",
      "icon": "📊",
      "version": "latest",
      "image": "grafana/grafana:latest",
      "ports": [{"port": 3000, "protocol": "tcp", "description": "Web 界面", "default": 3000}],
      "volumes": [
        {"containerPath": "/var/lib/grafana", "description": "数据目录", "default": "/opt/nas/apps/grafana/data"}
      ],
      "environment": {"GF_SECURITY_ADMIN_USER": "admin", "GF_SECURITY_ADMIN_PASSWORD": "admin123", "TZ": "Asia/Shanghai"},
      "notes": "支持多种数据源",
      "website": "https://grafana.com"
    },
    {
      "id": "prometheus",
      "name": "Prometheus",
      "displayName": "Prometheus",
      "description": "监控和时间序列数据库",
      "category": "Monitoring",
      "icon": "📈",
      "version": "latest",
      "image": "prom/prometheus:latest",
      "ports": [{"port": 9090, "protocol": "tcp", "description": "Web 界面", "default": 9090}],
      "volumes": [
        {"containerPath": "/etc/prometheus", "description": "配置文件", "default": "/opt/nas/apps/prometheus/config"},
        {"containerPath": "/prometheus", "description": "数据目录", "default": "/opt/nas/apps/prometheus/data"}
      ],
      "environment": {},
      "notes": "通常与 Grafana 配合使用",
      "website": "https://prometheus.io"
    },
    {
      "id": "nginx",
      "name": "Nginx",
      "displayName": "Nginx Proxy Manager",
      "description": "反向代理和 SSL 证书管理",
      "category": "Network",
      "icon": "🌐",
      "version": "latest",
      "image": "jc21/nginx-proxy-manager:latest",
      "ports": [
        {"port": 81, "protocol": "tcp", "description": "管理界面", "default": 81},
        {"port": 80, "protocol": "tcp", "description": "HTTP", "default": 80},
        {"port": 443, "protocol": "tcp", "description": "HTTPS", "default": 443}
      ],
      "volumes": [
        {"containerPath": "/data", "description": "数据目录", "default": "/opt/nas/apps/nginx/data"},
        {"containerPath": "/etc/letsencrypt", "description": "SSL 证书", "default": "/opt/nas/apps/nginx/letsencrypt"}
      ],
      "environment": {},
      "notes": "支持 Let's Encrypt 自动证书",
      "website": "https://nginxproxymanager.com"
    },
    {
      "id": "portainer",
      "name": "Portainer",
