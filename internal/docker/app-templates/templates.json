        {"containerPath": "/var/lib/postgresql/data", "description": "数据目录", "default": "/opt/nas/apps/postgres/data"}
      ],
      "environment": {"POSTGRES_USER": "postgres", "POSTGRES_PASSWORD": "postgres123", "POSTGRES_DB": "postgres"},
      "notes": "支持高级 SQL 特性",
      "website": "https://www.postgresql.org"
    },
    {
      "id": "mysql",
      "name": "MySQL",
      "displayName": "MySQL",
      "description": "流行的关系型数据库",
