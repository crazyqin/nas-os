      "image": "portainer/portainer-ce:latest",
      "ports": [{"port": 9000, "protocol": "tcp", "description": "Web 界面", "default": 9000}],
      "volumes": [
        {"containerPath": "/data", "description": "数据目录", "default": "/opt/nas/apps/portainer/data"},
        {"containerPath": "/var/run/docker.sock", "description": "Docker Socket", "default": "/var/run/docker.sock"}
      ],
      "environment": {},
      "notes": "提供友好的 Docker 管理界面",
      "website": "https://www.portainer.io"
    },
    {
      "id": "redis",
      "name": "Redis",
