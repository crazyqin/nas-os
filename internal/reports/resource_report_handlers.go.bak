// Package reports 提供资源报告增强API处理程序 (v2.89.0)
package reports

import (
	"time"

	"github.com/gin-gonic/gin"
	"nas-os/internal/api"
)

// ResourceReportAPIHandlers 资源报告API处理程序
type ResourceReportAPIHandlers struct {
	generator *ResourceReportGenerator
}

// NewResourceReportAPIHandlers 创建资源报告API处理程序
func NewResourceReportAPIHandlers(
	storageConfig StorageReportConfig,
	bandwidthConfig BandwidthReportConfig,
	capacityConfig CapacityPlanningConfig,
	costConfig StorageCostConfig,
) *ResourceReportAPIHandlers {
	return &ResourceReportAPIHandlers{
		generator: NewResourceReportGenerator(storageConfig, bandwidthConfig, capacityConfig, costConfig),
	}
}

// RegisterResourceReportRoutes 注册资源报告路由
func (h *ResourceReportAPIHandlers) RegisterResourceReportRoutes(apiGroup *gin.RouterGroup) {
	// 资源报告 API
	reports := apiGroup.Group("/resource-reports")
	{
		// 生成报告
		reports.POST("/generate", h.GenerateReport)

		// 存储使用报告
		reports.POST("/storage-usage", h.GenerateStorageUsageReport)
		reports.GET("/storage-usage/summary", h.GetStorageUsageSummary)
		reports.GET("/storage-usage/volumes", h.GetStorageVolumes)
		reports.GET("/storage-usage/users", h.GetStorageUsers)
		reports.GET("/storage-usage/trend", h.GetStorageTrend)

		// 带宽统计报告
		reports.POST("/bandwidth-stats", h.GenerateBandwidthStatsReport)
		reports.GET("/bandwidth-stats/summary", h.GetBandwidthSummary)
		reports.GET("/bandwidth-stats/interfaces", h.GetBandwidthInterfaces)
		reports.GET("/bandwidth-stats/trend", h.GetBandwidthTrend)

		// 容量预测报告
		reports.POST("/capacity-forecast", h.GenerateCapacityForecastReport)
		reports.GET("/capacity-forecast/summary", h.GetCapacitySummary)
		reports.GET("/capacity-forecast/milestones", h.GetCapacityMilestones)
		reports.GET("/capacity-forecast/predict/:months", h.PredictCapacity)

		// 综合报告
		reports.POST("/comprehensive", h.GenerateComprehensiveReport)
		reports.GET("/health-score", h.GetHealthScore)

		// 报告历史
		reports.GET("/history", h.GetReportHistory)
		reports.GET("/history/:id", h.GetReportByID)
	}
}

// GenerateReport 生成资源报告（统一入口）
func (h *ResourceReportAPIHandlers) GenerateReport(c *gin.Context) {
	var req ResourceReportRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		api.BadRequest(c, err.Error())
		return
	}

	// 设置默认值
	if req.StartTime == nil || req.EndTime == nil {
		now := time.Now()
		start := now.AddDate(0, 0, -30)
		req.StartTime = &start
		req.EndTime = &now
	}

	report := h.generator.GenerateReport(req)
	api.OK(c, report)
}

// GenerateStorageUsageReport 生成存储使用报告
func (h *ResourceReportAPIHandlers) GenerateStorageUsageReport(c *gin.Context) {
	var req ResourceReportRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		api.BadRequest(c, err.Error())
		return
	}

	req.Type = ResourceReportStorageUsage
	report := h.generator.GenerateReport(req)
	api.OK(c, report.StorageUsage)
}

// GetStorageUsageSummary 获取存储使用摘要
func (h *ResourceReportAPIHandlers) GetStorageUsageSummary(c *gin.Context) {
	now := time.Now()
	start := now.AddDate(0, 0, -30)

	req := ResourceReportRequest{
		Type:      ResourceReportStorageUsage,
		StartTime: &start,
		EndTime:   &now,
	}

	report := h.generator.GenerateReport(req)
	if report.StorageUsage != nil {
		api.OK(c, report.StorageUsage.Summary)
	} else {
		api.OK(c, StorageUsageSummary{})
	}
}

