// GetHealthScore 获取健康评分
func (h *ResourceReportAPIHandlers) GetHealthScore(c *gin.Context) {
	now := time.Now()
	start := now.AddDate(0, 0, -30)

	// 生成各类报告
	storageReq := ResourceReportRequest{
		Type:      ResourceReportStorageUsage,
		StartTime: &start,
		EndTime:   &now,
	}
	bandwidthReq := ResourceReportRequest{
		Type:      ResourceReportBandwidthStats,
		StartTime: &start,
		EndTime:   &now,
	}
	capacityReq := ResourceReportRequest{
		Type:         ResourceReportCapacity,
		StartTime:    &start,
		EndTime:      &now,
		ForecastDays: 90,
	}

	storageReport := h.generator.GenerateReport(storageReq)
	bandwidthReport := h.generator.GenerateReport(bandwidthReq)
	capacityReport := h.generator.GenerateReport(capacityReq)

	score := h.generator.CalculateHealthScore(
		storageReport.StorageUsage,
		bandwidthReport.BandwidthStats,
		capacityReport.CapacityForecast,
	)

	api.OK(c, gin.H{
		"score":        score,
		"status":       h.generator.GetHealthStatus(score),
		"generated_at": now,
	})
}

