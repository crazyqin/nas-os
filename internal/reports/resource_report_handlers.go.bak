// GenerateCapacityForecastReport 生成容量预测报告
func (h *ResourceReportAPIHandlers) GenerateCapacityForecastReport(c *gin.Context) {
	var req ResourceReportRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		api.BadRequest(c, err.Error())
		return
	}

	if req.ForecastDays == 0 {
		req.ForecastDays = 90
	}

	req.Type = ResourceReportCapacity
	report := h.generator.GenerateReport(req)
	api.OK(c, report.CapacityForecast)
}

